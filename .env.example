# ⚙️ Configuración de Recolecta Web
# Este es un archivo de EJEMPLO. Copia a .env y configura tus valores

# ==============================================
# 🚀 AMBIENTE
# ==============================================
ENVIRONMENT=development
DEBUG=true

# ==============================================
# 📱 FRONTEND
# ==============================================
# Puerto donde corre el frontend
VITE_PORT=3000
# URL del API backend
VITE_API_URL=http://localhost:8080
# URL base de la aplicación
VITE_BASE_URL=http://localhost:3000

# ==============================================
# 🔌 BACKEND API
# ==============================================
# Puerto del backend usado por Docker (dev y producción)
BACKEND_PORT=8081
# Puerto donde corre el backend (mantener igual a BACKEND_PORT)
API_PORT=8081
# Host donde escucha
API_HOST=0.0.0.0
# Clave secreta para JWT
API_SECRET_KEY=tu-clave-secreta-muy-segura-cambiar-en-produccion

# ==============================================
# 💾 BASE DE DATOS
# ==============================================
# PostgreSQL (valores de desarrollo listos para usar)
DATABASE_URL=postgresql://recolecta_dev:dev_password_123@db:5432/proyecto_recolecta
DB_HOST=db
DB_PORT=5432
DB_USER=recolecta_dev
DB_PASSWORD=dev_password_123
DB_NAME=proyecto_recolecta
DB_SSL_MODE=disable

# Redis (valores de desarrollo listos para usar)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_pass_456

# ==============================================
# 🌐 NGINX
# ==============================================
NGINX_PORT=80
NGINX_SSL_PORT=443
# Dominios (para producción)
NGINX_SERVER_NAME=localhost

# ==============================================
# 🔐 SEGURIDAD
# ==============================================
# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost
# Token JWT expiration (en minutos)
JWT_EXPIRATION=1440

# ==============================================
# 📧 EMAIL (Opcional - para notificaciones)
# ==============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-contrasena-app
SMTP_FROM=noreply@recolecta.local

# ==============================================
# 🔔 PUSH NOTIFICATIONS (Firebase / FCM)
# ==============================================
# Ruta al archivo de credenciales de la cuenta de servicio de Firebase.
# Desarrollo local: usa una ruta absoluta en tu maquina y manten el archivo fuera del repo.
# Produccion con Docker: apunta a la ruta interna donde el secreto se monta en el contenedor.
# Ejemplo en contenedor: /run/secrets/firebase_credentials.json
GOOGLE_APPLICATION_CREDENTIALS=

# ==============================================
# 🗺️ MAPAS (Opcional - para funcionalidades de geolocalización)
# ==============================================
GOOGLE_MAPS_API_KEY=tu-api-key
MAPBOX_TOKEN=tu-token

# ==============================================
# 📊 LOGS
# ==============================================
LOG_LEVEL=debug
LOG_FORMAT=json

# ==============================================
# ☁️ ALMACENAMIENTO (Opcional)
# ==============================================
# AWS S3 o similar
STORAGE_TYPE=local
STORAGE_BUCKET=recolecta-uploads
